{
  "expo": {
    "name": "SweatStreak",
    "slug": "sweatstreak",
    "scheme": "sweatstreak",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",

    "platforms": ["ios", "android", "web"],

    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sweatstreak.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0d0f0d"
      },
      "package": "com.sweatstreak.app",
      "edgeToEdgeEnabled": true
    },
    "extra": {
      "apiBaseUrl": "https://sweatstreak-backend.onrender.com"
    },
    "plugins": ["expo-font"]
  }
}
